prefix_rule(pattern=["git", "-C"], decision="allow")
prefix_rule(pattern=["sudo", "/home/ubuntu/.local/bin/uv"], decision="allow")
prefix_rule(pattern=["source", "/home/ubuntu/.profile"], decision="allow")
prefix_rule(pattern=["python3", "-c", "compile(open('/data/website/ops/scripts/collect_vps_status.py', encoding='utf-8').read(), '/data/website/ops/scripts/collect_vps_status.py', 'exec')"], decision="allow")
prefix_rule(pattern=["/home/ubuntu/.local/bin/uv", "run"], decision="allow")
prefix_rule(pattern=["python3", "-c", "from html.parser import HTMLParser; from pathlib import Path; p=HTMLParser(); p.feed(Path('public/wedding.josegperez.com/index.html').read_text()); print('html parsed')"], decision="allow")
prefix_rule(pattern=["curl"], decision="allow")
prefix_rule(pattern=["python3", "-m", "compileall"], decision="allow")
prefix_rule(pattern=["docker", "compose", "build"], decision="allow")
prefix_rule(pattern=["pnpm"], decision="allow")
